generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id          String    @id @default(cuid())
  name        String
  phone       String?
  reminderVia String    @default("WhatsApp")
  email       String?
  landline    String?
  referral    String?
  profession  String?
  gender      String?
  isForeign   Boolean   @default(false)
  birthDate   DateTime?
  cpf         String?
  rg          String?
  notes       String?

  emergencyName  String?
  emergencyPhone String?

  cep          String?
  street       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?

  guardianName      String?
  guardianCpf       String?
  guardianBirthDate DateTime?

  insurance          String  @default("Particular")
  insuranceHolder    String?
  insuranceCard      String?
  insuranceHolderCpf String?

  categories   Category[]
  appointments Appointment[]
  tasks        Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  patients Patient[]
}

model Professional {
  id           String        @id @default(cuid())
  name         String
  email        String?
  cro          String?
  type         String        @default("Dentista")
  appointments Appointment[]
  commitments  Commitment[]
  tasks        Task[]
}

model Chair {
  id           String        @id @default(cuid())
  name         String
  appointments Appointment[]
}

model Appointment {
  id             String        @id @default(cuid())
  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientId      String
  professional   Professional? @relation(fields: [professionalId], references: [id])
  professionalId String?
  chair          Chair?        @relation(fields: [chairId], references: [id])
  chairId        String?
  date           DateTime
  duration       Int           @default(30)
  notes          String?
  status         String        @default("Agendada")
  sendConfirmation Boolean     @default(true)
  returnIn       String?
  tag            String?
  createdAt      DateTime      @default(now())
}

model Commitment {
  id             String        @id @default(cuid())
  professional   Professional? @relation(fields: [professionalId], references: [id])
  professionalId String?
  title          String
  start          DateTime
  end            DateTime
  repeat         Boolean       @default(false)
  createdAt      DateTime      @default(now())
}

model Task {
  id             String        @id @default(cuid())
  title          String
  description    String?
  dueDate        DateTime?
  list           String        @default("Entrada")
  done           Boolean       @default(false)
  patient        Patient?      @relation(fields: [patientId], references: [id])
  patientId      String?
  professional   Professional? @relation(fields: [professionalId], references: [id])
  professionalId String?
  createdAt      DateTime      @default(now())
}
